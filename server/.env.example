NODE_ENV=development
PORT=4000
LOG_LEVEL=debug

# Mongo + Redis
MONGO_URI=mongodb://localhost:27017/blogplatform
REDIS_URL=redis://localhost:6379

# Auth
JWT_ACCESS_SECRET=change-me-dev-access-secret-32chars-min
JWT_REFRESH_SECRET=change-me-dev-refresh-secret-32chars-min
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# CORS
CLIENT_ORIGIN=http://localhost:5173

# GROQ
GROQ_API_KEY=
GROQ_MODERATION_MODEL=llama-3.3-70b-versatile

# JazzCash sandbox
JAZZCASH_MERCHANT_ID=
JAZZCASH_PASSWORD=
JAZZCASH_INTEGRITY_SALT=
JAZZCASH_RETURN_URL=http://localhost:5173/payments/return

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM="Blog Platform <noreply@example.com>"

# Observability
SENTRY_DSN=
