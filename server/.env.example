NODE_ENV=development
PORT=4000
LOG_LEVEL=debug

# Mongo + Redis
# Local (Docker):
MONGO_URI=mongodb://localhost:27017/blogplatform
REDIS_URL=redis://localhost:6379
# MongoDB Atlas (note: keep the /blogplatform db name before the ? and URL-encode the password):
#   MONGO_URI=mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/blogplatform?retryWrites=true&w=majority
# Upstash Redis (use the TCP "rediss://" connection string, NOT the REST URL — BullMQ needs TCP):
#   REDIS_URL=rediss://default:PASSWORD@your-db.upstash.io:6379

# Auth
JWT_ACCESS_SECRET=change-me-dev-access-secret-32chars-min
JWT_REFRESH_SECRET=change-me-dev-refresh-secret-32chars-min
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
# 'lax' for same-origin (single-service) deploys. Use 'none' (with COOKIE_SECURE=true)
# only when the SPA and API are on different domains.
COOKIE_SAMESITE=lax

# CORS
CLIENT_ORIGIN=http://localhost:5173

# Single-service deploy (one process serves the SPA + API + worker).
# Set both to true in production (e.g. on Render). Leave false for local dev,
# where Vite serves the client and `npm run dev:worker` runs the worker.
SERVE_CLIENT=false
RUN_WORKER=false

# OpenAI — powers moderation, the auto-content safety gate, AND the auto-content
# pipeline (web-search research + writing). https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODERATION_MODEL=gpt-4o-mini
OPENAI_CONTENT_MODEL=gpt-4o

# Automated daily article pipeline. Unsplash key: https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=
# Master switch for the recurring schedule. Worker runs whenever OPENAI_API_KEY is
# set (so the admin "generate now" endpoint works); set this true to enable cron.
AUTO_CONTENT_ENABLED=false
AUTO_CONTENT_CRON=0 9,18 * * *
AUTO_CONTENT_TZ=Asia/Karachi
AUTO_CONTENT_PER_RUN=1

# SEO. Google Search Console verification token (value of the
# google-site-verification meta tag); leave blank to omit the tag.
GOOGLE_SITE_VERIFICATION=
# IndexNow key (8-128 hex chars, e.g. `openssl rand -hex 16`). When set, newly
# published articles are pinged to IndexNow (Bing/Yandex/Naver/Seznam/Yep — NOT
# Google) and the proof file is served at /<key>.txt. Leave blank to disable.
INDEXNOW_KEY=

# Stripe (USD card payments — primary). Get keys from https://dashboard.stripe.com/test/apikeys
# For local webhooks run: stripe listen --forward-to localhost:4000/api/v1/payments/webhook/stripe
# and paste the printed "whsec_..." signing secret below.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# JazzCash sandbox (legacy, unused)
JAZZCASH_MERCHANT_ID=
JAZZCASH_PASSWORD=
JAZZCASH_INTEGRITY_SALT=
JAZZCASH_RETURN_URL=http://localhost:5173/payments/return

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM="Blog Platform <noreply@example.com>"

# Cloudinary image hosting (covers, inline article images, avatars).
# Create an unsigned-disabled (signed) account; the browser uploads directly
# using a server-generated signature. Recommended: also create an upload preset
# restricted to resource_type=image, allowed_formats jpg,png,webp,gif, and a
# max file size (~5MB) for defense in depth.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=blog

# Observability
SENTRY_DSN=
