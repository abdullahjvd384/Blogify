{
  "name": "webprog-project",
  "private": true,
  "version": "0.1.0",
  "description": "Blog platform MVP — monorepo (client + server + workers + shared).",
  "type": "module",
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "scripts": {
    "dev": "concurrently -k -n server,worker,client -c blue,magenta,green \"npm:dev:server\" \"npm:dev:worker\" \"npm:dev:client\"",
    "dev:server": "npm run dev --workspace=server",
    "dev:worker": "npm run dev:worker --workspace=server",
    "dev:client": "npm run dev --workspace=client",
    "build": "npm run build --workspaces --if-present",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:seed": "node scripts/seed.js",
    "db:sync-indexes": "node scripts/sync-indexes.js",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "concurrently": "^9.1.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "prettier": "^3.4.2"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "lint-staged": {
    "*.{js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,css,html}": [
      "prettier --write"
    ]
  }
}
